# BauPlayerMusic Python 后端配置模板。
# 复制本文件为 `.env` 后再修改；`.env` 已被 Git 忽略，禁止提交真实密钥。
# 相对路径均以 mds.py / DDNet-Server.exe 所在目录为基准。
# Windows 路径建议使用正斜杠，例如 D:/BauPlayerMusic/data/musicso。

# ==================== 后端监听 ====================

# 只供同一台服务器上的 DDNet 访问时保持 127.0.0.1，不要开放到公网。
BPMUSIC_HOST=127.0.0.1
# 必须与 myServerconfig.cfg 的 sv_music_backend_url 端口一致。
BPMUSIC_PORT=5000

# ==================== 网易云与本地文件 ====================

# 网易云接口基础地址，一般不需要修改。
BPMUSIC_NETEASE_BASE_URL=http://music.163.com
# 下载后的 Opus 音频与歌词目录；运行时自动创建。
BPMUSIC_DOWNLOAD_DIR=data/musicso
# 专辑封面目录；运行时自动创建。
BPMUSIC_COVER_DIR=data/musicso/covers
# 网易云登录 Cookie 文件。文件可能含账号凭据，严禁提交 Git。
BPMUSIC_COOKIE_FILE=netease_cookies.json

# 原始、未缝入音乐的地图目录。本仓库已提供 data/originmaps/a.map。
BPMUSIC_ORIGIN_MAPS_DIR=data/originmaps
# 地图缝合候选产物目录；运行时自动创建，不提交 Git。
BPMUSIC_PREPARED_MAPS_DIR=data/musico/prepared_maps
# 服务端安装/上传地图时使用的缓存目录；运行时自动创建。
BPMUSIC_WEBMAPS_BASE_PATH=data/webmaps

# music_map_patcher.exe 路径。留空会优先查找后端同目录下的程序。
BPMUSIC_MAP_PATCHER=
# 单次地图缝合最长等待秒数。
BPMUSIC_MAP_PATCHER_TIMEOUT=90
# 并发下载/上传工作线程数。小型 Windows Server 建议 2。
BPMUSIC_UPLOAD_WORKERS=2

# 服务端播放队列文件。留空时 Windows 默认使用
# %APPDATA%/DDNet/data/musico/playlist.txt；自定义 DDNet 存储路径时请填写绝对路径。
BPMUSIC_PLAYLIST_FILE=

# ==================== 统计与小游戏数据 ====================

# 以下 SQLite 文件由程序自动创建，均已被 Git 忽略。
BPMUSIC_STATS_DB=data/musico/music_history.sqlite3
BPMUSIC_UNDERCOVER_DB=data/musico/undercover.sqlite3
# 谁是卧底词库（源码仓库已包含）。
BPMUSIC_UNDERCOVER_WORDS=data/musico/undercover_words.txt
BPMUSIC_TURTLE_SOUP_DB=data/musico/turtle_soup.sqlite3
# 海龟汤 JSON 题库（源码仓库已包含，缺失时只会剩少量内置题目）。
BPMUSIC_TURTLE_SOUP_CASES=data/musico/turtle_soup_cases.json

# 海龟汤自由问答可选的 DeepSeek 配置。未填写 Key 时仍可使用本地题库与关键词逻辑。
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# 同一玩家及全局的海龟汤提问冷却，单位秒。
TURTLE_SOUP_PLAYER_COOLDOWN=4
TURTLE_SOUP_GLOBAL_COOLDOWN=0.8

# ==================== NapCat / QQBot（可选） ====================

# 配置完成 NapCat OneBot 11 WebSocket 服务端前保持 0。
BPMUSIC_QQBOT_ENABLED=0
# NapCat WebSocket 地址；同机部署通常为 127.0.0.1:3001。
BPMUSIC_QQBOT_WS_URL=ws://127.0.0.1:3001
# 必须与 NapCat 网络配置中生成的 Access Token 完全一致。
BPMUSIC_QQBOT_ACCESS_TOKEN=
# 允许使用机器人的 QQ 群号，多个群用英文逗号分隔。
BPMUSIC_QQBOT_GROUP_IDS=
# QQ 查询队列时最多返回的歌曲数。
BPMUSIC_QQBOT_MAX_SONGS=10
# WebSocket 断线重连间隔，单位秒。
BPMUSIC_QQBOT_RECONNECT_SECONDS=5

# 后端与 DDNet 服务端之间的独立共享密钥，不是 NapCat Access Token。
# 请生成至少 64 位随机字符串，并同时填入 myServerconfig.cfg 的 sv_music_qq_token。
BPMUSIC_QQBOT_SERVER_TOKEN=
# QQ/游戏消息转发限流。
BPMUSIC_QQBOT_RELAY_GLOBAL_COOLDOWN=5
BPMUSIC_QQBOT_RELAY_USER_COOLDOWN=30
BPMUSIC_QQBOT_RELAY_MAX_LENGTH=160

# ==================== S3 / 对象存储（可选） ====================

# 只在需要把缝好音乐的地图上传到对象存储时填写；本地播放可全部留空。
# 雨云同地域内网示例：https://cn-nb1.internal.rains3.com
# 若内网域名 443 不通，先确认服务器实例已分配同地域私网 IP。
BPMUSIC_S3_ENDPOINT_URL=
BPMUSIC_S3_ACCESS_KEY=
BPMUSIC_S3_SECRET_KEY=
BPMUSIC_S3_BUCKET_NAME=
# 玩家客户端下载地图使用的公网域名或 CDN 域名，不应填写内网端点。
BPMUSIC_S3_PUBLIC_DOMAIN=
# 通常留空；仅在存储服务明确支持且需要时填写 public-read。
BPMUSIC_S3_OBJECT_ACL=

# 仅 mds_aliyun.py 使用。留空时尝试从 BPMUSIC_S3_ENDPOINT_URL 推导。
# 阿里云同地域内网端点示例：https://oss-cn-heyuan-internal.aliyuncs.com
BPMUSIC_ALIYUN_OSS_ENDPOINT=
